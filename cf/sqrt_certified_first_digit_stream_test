// sqrt_certified_first_digit_stream_test.go v5
package cf

import "testing"

func TestSqrtCertifiedFirstDigitCFStream_FinitePerfectSquare_EmitsExactResult(t *testing.T) {
	s, err := NewSqrtCertifiedFirstDigitCFStream(NewSliceCF(4), 8)
	if err != nil {
		t.Fatalf("constructor failed: %v", err)
	}

	got := collectTerms(s, 8)
	if err := s.Err(); err != nil {
		t.Fatalf("stream error: %v", err)
	}

	want := []int64{2}
	if len(got) != len(want) {
		t.Fatalf("len(got)=%d want=%d got=%v", len(got), len(want), got)
	}
	if got[0] != want[0] {
		t.Fatalf("got %v want %v", got, want)
	}
	if snap := s.Snapshot(); snap.Status != SqrtStreamStatusCertifiedProgressive {
		t.Fatalf("got status %q want %q", snap.Status, SqrtStreamStatusCertifiedProgressive)
	}
}

func TestSqrtCertifiedFirstDigitCFStream_Sqrt2_RefinesAndContinues(t *testing.T) {
	s, err := NewSqrtCertifiedFirstDigitCFStream(Sqrt2CF(), 12)
	if err != nil {
		t.Fatalf("constructor failed: %v", err)
	}

	got := collectTerms(s, 8)
	if err := s.Err(); err != nil {
		t.Fatalf("stream error: %v", err)
	}

	wantPrefix := []int64{1, 2, 2, 2}
	if len(got) < len(wantPrefix) {
		t.Fatalf("len(got)=%d want at least %d got=%v", len(got), len(wantPrefix), got)
	}
	for i := range wantPrefix {
		if got[i] != wantPrefix[i] {
			t.Fatalf("got[%d]=%d want=%d full=%v", i, got[i], wantPrefix[i], got)
		}
	}

	snap := s.Snapshot()
	if snap.Status != SqrtStreamStatusCertifiedProgressive {
		t.Fatalf("got status %q want %q", snap.Status, SqrtStreamStatusCertifiedProgressive)
	}
	if snap.PrefixTerms > 12 {
		t.Fatalf("used too many terms: got %d want <= 12", snap.PrefixTerms)
	}
}

func TestSqrtCertifiedFirstDigitCFStream_RejectsBadBound(t *testing.T) {
	_, err := NewSqrtCertifiedFirstDigitCFStream(Sqrt2CF(), 0)
	if err == nil {
		t.Fatalf("expected constructor error")
	}
}

func TestSqrtCertifiedFirstDigitCFStream_EmptySourceFails(t *testing.T) {
	s, err := NewSqrtCertifiedFirstDigitCFStream(NewSliceCF(), 4)
	if err != nil {
		t.Fatalf("constructor failed: %v", err)
	}

	_, ok := s.Next()
	if ok {
		t.Fatalf("expected failure, not a digit")
	}
	if s.Err() == nil {
		t.Fatalf("expected non-nil error")
	}
	if snap := s.Snapshot(); snap.Status != SqrtStreamStatusFailed {
		t.Fatalf("got status %q want %q", snap.Status, SqrtStreamStatusFailed)
	}
}

